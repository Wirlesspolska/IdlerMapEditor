# Copy to .env or let ./deploy.sh generate it.
RUST_LOG=sharemarketplace=info,tower_http=info

# Host port for the API (default compose publishes this)
MARKETPLACE_PUBLISH=8787

# Used only with: docker compose --profile proxy up -d
# or ./deploy.sh up --domain ...
MARKETPLACE_HOST=marketplace.example.com
MARKETPLACE_BASE_DOMAIN=example.com
ACME_EMAIL=you@example.com
SHAREMARKETPLACE_TLS_ALLOW_HOST=marketplace.example.com
SHAREMARKETPLACE_TLS_ALLOW_SUFFIX=
